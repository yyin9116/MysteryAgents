# Root environment template for local demo release
# Backend runtime variables are loaded from backend/.env
# Frontend runtime variables are loaded from frontend/.env

# Frontend
VITE_API_BASE_URL=http://localhost:8000

# Backend
HOST=0.0.0.0
PORT=8000
DEBUG=false
OPENAI_API_KEY=sk-your-openai-key-here
ALIBABA_API_KEY=sk-your-alibaba-key-here
ALIBABA_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
MODEL_HIGH_IQ=openai/gpt-4o
MODEL_MID_IQ=alibaba/qwen-turbo
MODEL_LOW_IQ=alibaba/qwen-plus
CORS_ORIGINS=http://localhost:5173,http://localhost:4173
LOG_LEVEL=INFO
