# ============================================
# Undercover AI Sandbox - Backend Configuration
# Local demo edition
# ============================================
# Copy this file to .env and fill in your values.
# Do not commit the generated .env file.

# Server Configuration
HOST=0.0.0.0
PORT=8000
DEBUG=false

# LLM Provider API Keys
OPENAI_API_KEY=sk-your-openai-key-here
ALIBABA_API_KEY=sk-your-alibaba-key-here
ALIBABA_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here
# ZHIPU_API_KEY=your-zhipu-api-key-here
OLLAMA_BASE_URL=http://localhost:11434

# Model Mapping for IQ Levels
MODEL_HIGH_IQ=openai/gpt-4o
MODEL_MID_IQ=alibaba/qwen-turbo
MODEL_LOW_IQ=alibaba/qwen-plus

# Memory System Configuration
MEMORY_PROVIDER=qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6333
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Memory Decay Settings
MEMORY_DECAY_HIGH=0.05
MEMORY_DECAY_MID=0.15
MEMORY_DECAY_LOW=0.30
MEMORY_CASCADE_PROBABILITY=0.5

# State Management
CHECKPOINT_INTERVAL=5
STORAGE_PATH=./game_states

# Database Configuration
DATABASE_URL=sqlite:///./undercover_ai.db

# Optional Redis cache
# REDIS_URL=redis://localhost:6379/0

# CORS Configuration
CORS_ORIGINS=http://localhost:5173,http://localhost:4173

# Logging
LOG_LEVEL=INFO
LITELLM_LOG=INFO

# LLM Configuration
LLM_TIMEOUT=30
LLM_MAX_RETRIES=3

# Game Configuration
DEFAULT_AGENT_COUNT=6
DEFAULT_ROUND_LIMIT=10
